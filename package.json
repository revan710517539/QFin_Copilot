{
  "name": "credit-dashboard",
  "version": "1.0.0",
  "private": true,
  "main": "build/electron.js",
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^2.1.1",
    "ajv-keywords": "^5.1.0",
    "antd": "^5.15.0",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "schema-utils": "^3.3.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "PUBLIC_URL=. react-scripts build",
    "electron": "electron electron/main.js",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "build": {
    "appId": "com.revan.creditdashboard",
    "productName": "Credit Dashboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.finance"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
